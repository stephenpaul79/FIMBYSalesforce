# Copy to .env and fill in. .env is gitignored.

# Site under test
FIMBY_BASE_URL=https://our.fimby.com

# Optional: full https://fimby.file.force.com/.../renditionDownload?... URL so global-setup
# can pre-warm the file domain when no feed img is found in time. Copy from DevTools img[src]
# on any post with an image. All personas use the same org file domain; one URL is enough.
# FIMBY_FILE_PREWARM_URL=https://fimby.file.force.com/sfc/dist/version/renditionDownload?rendition=...

# Personas (per qa-testing-login.mdc)
# Owner = Desktop Tester (primary), R1 = Mobile Tester (alternate), R2 = SF Tester
FIMBY_OWNER_EMAIL=desktop@fimby.com
FIMBY_R1_EMAIL=mobiletester@fimby.com
FIMBY_R2_EMAIL=sftester@fimby.com
FIMBY_PERSONA_PASSWORD=dtes4Jesus!

# Salesforce CLI alias used by cleanup helpers (sf apex run --target-org $SF_ORG_ALIAS)
SF_ORG_ALIAS=fimby-prod

# CI-only: full sfdx auth URL pasted into auth-url.txt by the workflow.
# Locally, you authenticate once with `sf org login web -a fimby-prod` and leave SF_AUTH_URL unset.
# SF_AUTH_URL=force://...
