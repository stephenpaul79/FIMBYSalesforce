{
  "name": "fimby-tests-e2e",
  "version": "0.1.0",
  "private": true,
  "description": "Playwright end-to-end suite for FIMBY pre-launch QA. Translates the QA runbooks in C:/Users/srathjen/.cursor/plans/*_qa.plan.md into automated specs.",
  "scripts": {
    "test": "playwright test",
    "test:smoke": "playwright test --grep @smoke",
    "test:smoke:ui": "playwright test --grep @smoke --ui",
    "test:smoke:log": "node playwright/run-smoke-log.mjs",
    "test:search:ui": "playwright test tests/kebab-search.spec.ts --grep @smoke --ui",
    "test:regression": "playwright test --grep \"@smoke|@regression\"",
    "test:polish": "playwright test --grep @polish",
    "test:headed": "playwright test --headed",
    "auth:refresh": "tsx playwright/refresh-auth.ts",
    "cleanup:dryrun": "tsx playwright/helpers/cleanup-cli.ts dryrun",
    "report": "playwright show-report"
  },
  "devDependencies": {
    "@playwright/test": "^1.48.0",
    "@types/node": "^22.0.0",
    "dotenv": "^16.4.5",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
