<?xml version="1.0" encoding="UTF-8"?>
<LightningComponentBundle xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>59.0</apiVersion>
    <isExposed>true</isExposed>
    <targets>
        <target>lightning__RecordPage</target>
        <target>lightning__AppPage</target>
        <target>lightning__HomePage</target>
        <target>lightningCommunity__Page</target>
        <target>lightningCommunity__Default</target>
    </targets>
    <targetConfigs>
        <targetConfig targets="lightningCommunity__Default">
            <property name="threshold" type="Integer" default="300" label="Load More Threshold" description="Distance from bottom (px) to trigger loading more content"/>
            <property name="enablePullToRefresh" type="Boolean" default="true" label="Enable Pull to Refresh"/>
            <property name="emptyStateTitle" type="String" default="Nothing here yet" label="Empty State Title"/>
            <property name="emptyStateMessage" type="String" default="Check back later for new content" label="Empty State Message"/>
            <property name="emptyStateIcon" type="String" default="utility:inbox" label="Empty State Icon"/>
            <property name="showEmptyAction" type="Boolean" default="false" label="Show Empty Action Button"/>
            <property name="emptyActionLabel" type="String" default="Add Content" label="Empty Action Button Label"/>
        </targetConfig>
    </targetConfigs>
</LightningComponentBundle>