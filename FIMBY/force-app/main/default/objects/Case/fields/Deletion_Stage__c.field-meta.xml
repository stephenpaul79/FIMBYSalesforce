<?xml version="1.0" encoding="UTF-8"?>
<CustomField xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Deletion_Stage__c</fullName>
    <description>Stage of the email-to-case account-deletion flow. Awaiting Confirmation = verification email sent, waiting on user reply. Confirmed = user replied CONFIRM DELETE, 24h safeguard counting down. Completed = enqueueDeletion fired and Contact flagged. Cancelled = user replied CANCEL or sender did not match an active user. Expired = no reply within 7 days.</description>
    <label>Deletion Stage</label>
    <required>false</required>
    <trackFeedHistory>false</trackFeedHistory>
    <trackTrending>false</trackTrending>
    <type>Picklist</type>
    <valueSet>
        <restricted>true</restricted>
        <valueSetDefinition>
            <sorted>false</sorted>
            <value>
                <fullName>Awaiting Confirmation</fullName>
                <default>false</default>
                <label>Awaiting Confirmation</label>
            </value>
            <value>
                <fullName>Confirmed</fullName>
                <default>false</default>
                <label>Confirmed</label>
            </value>
            <value>
                <fullName>Completed</fullName>
                <default>false</default>
                <label>Completed</label>
            </value>
            <value>
                <fullName>Cancelled</fullName>
                <default>false</default>
                <label>Cancelled</label>
            </value>
            <value>
                <fullName>Expired</fullName>
                <default>false</default>
                <label>Expired</label>
            </value>
        </valueSetDefinition>
    </valueSet>
</CustomField>
