<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Postal_Codes</fullName>
    <active>true</active>
    <errorConditionFormula>NOT(REGEX( Name , &quot;^(?!.*[DFIOQU])[A-VXY][0-9][A-Z] ?[0-9][A-Z][0-9]$&quot;
    )) 
||
LEN(Name) !=7</errorConditionFormula>
    <errorDisplayField>Name</errorDisplayField>
    <errorMessage>Postal Codes must be formatted with the following format:  X1X 1X1</errorMessage>
</ValidationRule>
