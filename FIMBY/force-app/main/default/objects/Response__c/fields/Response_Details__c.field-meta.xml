<?xml version="1.0" encoding="UTF-8"?>
<CustomField xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Response_Details__c</fullName>
    <description>Dynamically Displays the Response if Public or Private</description>
    <externalId>false</externalId>
    <formula>IF(Private__c = TRUE &amp;&amp; $User.Id != OwnerId &amp;&amp; $User.Id != Need_Offer_Responded_To__r.OwnerId,  &quot;&lt;PRIVATE&gt;&quot;,  Response__c)</formula>
    <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
    <label>Response Message</label>
    <required>false</required>
    <trackHistory>false</trackHistory>
    <trackTrending>false</trackTrending>
    <type>Text</type>
    <unique>false</unique>
</CustomField>
