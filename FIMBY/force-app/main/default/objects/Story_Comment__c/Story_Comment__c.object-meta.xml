<?xml version="1.0" encoding="UTF-8"?>
<CustomObject xmlns="http://soap.sforce.com/2006/04/metadata">
    <deploymentStatus>Deployed</deploymentStatus>
    <description>Comments on Story records. Replaces Chatter FeedItem for story comments. Dual-stamped (Posted_By__c = represented identity, Contact__c = real author), neighbourhood-scoped, and integrated with the FIMBY moderation pipeline.</description>
    <enableActivities>false</enableActivities>
    <enableBulkApi>true</enableBulkApi>
    <enableHistory>true</enableHistory>
    <enableReports>true</enableReports>
    <enableSearch>false</enableSearch>
    <enableSharing>true</enableSharing>
    <enableStreamingApi>true</enableStreamingApi>
    <label>Story Comment</label>
    <nameField>
        <displayFormat>SC-{000000}</displayFormat>
        <label>Story Comment Number</label>
        <type>AutoNumber</type>
    </nameField>
    <pluralLabel>Story Comments</pluralLabel>
    <sharingModel>ControlledByParent</sharingModel>
</CustomObject>
