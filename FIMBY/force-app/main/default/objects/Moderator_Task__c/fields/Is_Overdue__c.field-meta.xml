<?xml version="1.0" encoding="UTF-8"?>
<CustomField xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Is_Overdue__c</fullName>
    <description>True when the task has been open more than 24 hours and has not been resolved. Drives the overdue badge on the moderator dashboard.</description>
    <externalId>false</externalId>
    <formula>AND(
  Hours_Open__c &gt; 24,
  NOT(ISPICKVAL(Status__c, &quot;Resolved&quot;)),
  NOT(ISPICKVAL(Status__c, &quot;Dismissed&quot;)),
  NOT(ISPICKVAL(Status__c, &quot;Escalated&quot;))
)</formula>
    <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
    <label>Is Overdue</label>
    <required>false</required>
    <trackTrending>false</trackTrending>
    <type>Checkbox</type>
</CustomField>
