                <componentInstanceProperties>
                    <name>richTextValue</name>
                    <value>&lt;p&gt;&lt;span style=&quot;font-size:16px;&quot;&gt;Hi {{{Recipient.FirstName}}}! 🌱&lt;/span&gt;&lt;/p&gt;

&lt;p&gt;&lt;span style=&quot;font-size:16px;&quot;&gt;Welcome to FIMBY 🏡&amp;mdash; your new tool for connecting with neighbors, sharing resources, and growing in faith. We&amp;rsquo;re thrilled you&amp;rsquo;ve joined us! 🌈🤝&lt;br /&gt;
&lt;br /&gt;
Here&amp;rsquo;s what FIMBY can do for you:&lt;/span&gt;&lt;/p&gt;

&lt;p&gt;&lt;span style=&quot;font-size:16px;&quot;&gt;&lt;strong&gt;Promote Spiritual Growth:&lt;/strong&gt; Integrate hospitality, service, and stewardship into everyday life, helping you (and your neighbors) grow spiritually. 🕊️🌟&lt;/span&gt;&lt;/p&gt;

&lt;p&gt;&lt;span style=&quot;font-size:16px;&quot;&gt;&lt;strong&gt;Build Local Connections:&lt;/strong&gt; Foster meaningful relationships by connecting you with fellow believers and community members right where you live. 👥💬&lt;/span&gt;&lt;/p&gt;

&lt;p&gt;&lt;span style=&quot;font-size:16px;&quot;&gt;&lt;strong&gt;Combat Consumerism and Bias:&lt;/strong&gt; Share resources, widen your perspective, and practice generosity&amp;mdash;together we can nurture empathy in our communities. 🔄🌍&lt;/span&gt;&lt;/p&gt;

&lt;p&gt;&lt;span style=&quot;font-size:16px;&quot;&gt;&lt;strong&gt;Foster a &amp;lsquo;We&amp;rsquo; not &amp;lsquo;Me&amp;rsquo; Culture:&lt;/strong&gt; Put unity into action by identifying and meeting collective needs in your neighborhood. 🤲❤️&lt;/span&gt;&lt;/p&gt;

&lt;p&gt;&lt;span style=&quot;font-size:16px;&quot;&gt;&lt;strong&gt;Democratize Access:&lt;/strong&gt; Everyone&amp;rsquo;s welcome&amp;mdash;FIMBY doesn&amp;rsquo;t require the latest tech or extensive online skills, ensuring inclusivity for all. 🌐🚪&lt;/span&gt;&lt;/p&gt;

&lt;p&gt;&lt;strong&gt;&lt;span style=&quot;font-size:16px;&quot;&gt;Ready to Dive In?&amp;nbsp;&lt;/span&gt;&lt;/strong&gt;&lt;span style=&quot;font-size:16px;&quot;&gt;🤿&amp;nbsp;Click below to start exploring:&lt;/span&gt;&lt;/p&gt;

&lt;p&gt;&lt;span style=&quot;font-size:16px;&quot;&gt;🔗 &lt;strong&gt;&lt;a href=&quot;https://fimby.my.site.com/login&quot; rel=&quot;noreferrer&quot; target=&quot;_new&quot;&gt;Login to FIMBY&lt;/a&gt;&lt;/strong&gt;&lt;/span&gt;&lt;/p&gt;

&lt;p&gt;&lt;span style=&quot;font-size:16px;&quot;&gt;&lt;strong&gt;Username:&lt;/strong&gt; {{{Recipient.FIMBY_Username__c}}}&lt;/span&gt;&lt;/p&gt;

&lt;p&gt;&lt;span style=&quot;font-size:16px;&quot;&gt;&lt;strong&gt;Password:&lt;/strong&gt; {{{Recipient.Current_Password__c}}}&lt;/span&gt;&lt;/p&gt;

&lt;p&gt;&lt;span style=&quot;font-size:16px;&quot;&gt;&lt;strong&gt;Reset Email:&lt;/strong&gt; {{{Recipient.FIMBY_Reset_Email__c}}}&lt;/span&gt;&lt;/p&gt;

&lt;p&gt;&lt;span style=&quot;font-size:16px;&quot;&gt;📌 &lt;strong&gt;Note:&lt;/strong&gt; Your entire household shares this account. Bookmark the login page, store your password securely, and if needed, request a reset link from the email above.&lt;br /&gt;
&lt;br /&gt;
&lt;strong&gt;Need a Quick Tour?&amp;nbsp;&lt;/strong&gt;&lt;/span&gt;📽️🎬&lt;br /&gt;
&lt;span style=&quot;font-size:16px;&quot;&gt;Check out our 15-minute FIMBY Fundamentals &lt;a href=&quot;https://youtu.be/f6nf5oKDZLk?si=HnPQdbxFSoRX0IIK&quot;&gt;YouTube video&lt;/a&gt; for a walkthrough of all the essentials. You&amp;rsquo;ll be sowing seeds of love in no time!&lt;br /&gt;
&lt;br /&gt;
With hope and gratitude,&lt;br /&gt;
Stephen Rathjen 🌳&lt;/span&gt;&lt;br /&gt;
&lt;span style=&quot;font-size:14px;&quot;&gt;FIMBY Founder&lt;/span&gt;&lt;/p&gt;

&lt;p style=&quot;text-align: center;&quot;&gt;&lt;span style=&quot;font-size:16px;&quot;&gt;&amp;ldquo;&lt;em&gt;With great power comes great responsibility.&lt;/em&gt;&amp;rdquo; Uncle Ben 😉🌱&lt;/span&gt;&lt;/p&gt;

&lt;p&gt;&lt;span style=&quot;font-size:16px;&quot;&gt;&lt;strong&gt;P.S.&lt;/strong&gt; Reach out anytime if you have questions, feedback, or just want to say hi!&amp;nbsp;&lt;/span&gt;&lt;br /&gt;
&amp;nbsp;&lt;/p&gt;</value>
